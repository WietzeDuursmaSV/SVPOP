{
  "name": "sv-pop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.presentation.config.js",
    "cache:clean": "rm -rf node_modules/.vite node_modules/.vite-presentation node_modules/.vite-control",
    "ports:free": "kill-port 3001 5173 5174",
    "dev:api": "node server/todo-server.js",
    "dev:presentation": "vite --config vite.presentation.config.js",
    "dev:control": "vite --config vite.control.config.js",
    "dev:all": "npm run ports:free && npm run cache:clean && concurrently \"npm run dev:api\" \"npm run dev:presentation\" \"npm run dev:control\"",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "html2pdf.js": "^0.10.3",
    "vue": "^3.5.34"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "prettier": "^3.8.4",
    "vite": "^8.0.12"
  }
}
